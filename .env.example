# Get your free Gemini API Key at https://aistudio.google.com/app/apikey
# This is a server-side secret, DO NOT prefix with VITE_
GEMINI_API_KEY=your_api_key_here

# For GitHub Pages, set this to your repo name, e.g., /my-repo-name/
# Leave empty or set to / if deploying to a custom domain or root
VITE_BASE_PATH=/
